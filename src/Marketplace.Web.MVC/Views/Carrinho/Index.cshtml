@model Marketplace.Web.MVC.Models.Carrinho.CarrinhoSession
@{
    ViewData["Title"] = "Meu Carrinho";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Início</a></li>
        <li class="breadcrumb-item active">Meu Carrinho</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cart3 me-2"></i>Meu Carrinho
        @if (Model.TotalItens > 0)
        {
            <span class="badge rounded-pill ms-2" style="background:var(--color-accent);color:#000;font-size:0.8rem;">@Model.TotalItens</span>
        }
    </h4>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Continuar Comprando
    </a>
</div>

@if (!Model.Itens.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size:5rem;color:var(--color-text-muted)"></i>
        <h5 class="mt-3" style="color:var(--color-text-muted)">Seu carrinho está vazio</h5>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-shop me-2"></i>Ver Produtos
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Itens (70%) -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    @foreach (var item in Model.Itens)
                    {
                        <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                            <!-- Ícone produto -->
                            <div class="flex-shrink-0 text-center" style="width:56px;height:56px;background:rgba(255,255,255,0.04);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-box-seam fs-4" style="color:var(--color-text-muted)"></i>
                            </div>
                            <!-- Nome e preço unitário -->
                            <div class="flex-grow-1 min-width-0">
                                <p class="fw-semibold mb-0 text-truncate">@item.Nome</p>
                                <small style="color:var(--color-text-muted)">R$ @item.Preco.ToString("N2") / un.</small>
                            </div>
                            <!-- Controles +/- -->
                            <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                <form asp-action="AtualizarQuantidade" method="post">
                                    <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                    <input type="hidden" name="quantidade" value="@(item.Quantidade - 1)" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2"
                                            @(item.Quantidade <= 1 ? "disabled" : "")>
                                        <i class="bi bi-dash"></i>
                                    </button>
                                </form>
                                <span class="fw-bold px-2 text-center" style="min-width:2rem;">@item.Quantidade</span>
                                <form asp-action="AtualizarQuantidade" method="post">
                                    <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                    <input type="hidden" name="quantidade" value="@(item.Quantidade + 1)" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <!-- Subtotal -->
                            <div class="text-end flex-shrink-0" style="min-width:90px;">
                                <p class="fw-bold mb-0" style="color:var(--color-accent);">R$ @item.Subtotal.ToString("N2")</p>
                            </div>
                            <!-- Remover -->
                            <form asp-action="Remover" method="post" class="flex-shrink-0">
                                <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                <button type="submit" class="btn btn-link p-0" style="color:var(--color-danger)"
                                        onclick="return confirm('Remover este item?')" title="Remover">
                                    <i class="bi bi-trash fs-5"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <form asp-action="Limpar" method="post" class="mt-3">
                <button type="submit" class="btn btn-outline-secondary btn-sm"
                        onclick="return confirm('Esvaziar o carrinho?')">
                    <i class="bi bi-trash me-1"></i>Esvaziar Carrinho
                </button>
            </form>
        </div>

        <!-- Resumo (30%) -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 sticky-top" style="top:80px;">
                <div class="card-header fw-semibold py-3">
                    <i class="bi bi-receipt me-2"></i>Resumo
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal (@Model.TotalItens itens)</span>
                        <span>R$ @Model.Total.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small" style="color:var(--color-text-muted)">
                        <span><i class="bi bi-truck me-1"></i>Frete</span>
                        <span>Calculado no checkout</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span style="color:var(--color-accent)">R$ @Model.Total.ToString("N2")</span>
                    </div>
                    <p class="small mt-1 mb-3" style="color:var(--color-text-muted)">
                        ou 12x R$ @((Model.Total / 12).ToString("N2")) sem juros
                    </p>
                    <div class="d-grid">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg">
                                <i class="bi bi-credit-card me-2"></i>Finalizar Compra
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Conta" asp-action="Login"
                               asp-route-returnUrl="/Checkout" class="btn btn-success btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Entrar para Comprar
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
