<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#04162d" />
    <title>@ViewData["Title"] - Marketplace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            <i class="bi bi-shop"></i> Marketplace
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                style="border-color: rgba(215,160,49,0.3);">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i> Início
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Produtos" asp-action="Index">
                        <i class="bi bi-grid"></i> Produtos
                    </a>
                </li>
            </ul>

            <form class="d-flex me-3" asp-controller="Home" asp-action="Buscar" method="get">
                <input class="form-control form-control-sm me-2" type="search" name="q" placeholder="Buscar produtos..." />
                <button class="btn btn-outline-light btn-sm" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </form>

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Carrinho" asp-action="Index">
                            <i class="bi bi-cart3"></i>
                            @{
                                var qtd = ViewBag.CarrinhoQtd as int? ?? 0;
                            }
                            @if (qtd > 0)
                            {
                                <span class="badge bg-danger rounded-pill">@qtd</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Conta" asp-action="Perfil"><i class="bi bi-person me-2"></i>Meu Perfil</a></li>
                            <li><a class="dropdown-item" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-bag me-2"></i>Meus Pedidos</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Conta" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item" style="color:var(--color-danger)">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sair
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Conta" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i> Entrar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm ms-2" asp-controller="Conta" asp-action="Cadastro">
                            Cadastrar-se
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- Toast container -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
    @if (TempData["ToastSucesso"] != null)
    {
        <div class="toast align-items-center text-bg-success border-0" role="alert" data-bs-autohide="true" data-bs-delay="4000">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["ToastSucesso"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
    @if (TempData["ToastErro"] != null)
    {
        <div class="toast align-items-center text-bg-danger border-0" role="alert" data-bs-autohide="true" data-bs-delay="4000">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ToastErro"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>

<div class="container py-4">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="footer py-4 mt-5">
    <div class="container text-center">
        <p class="mb-0">&copy; 2026 Marketplace — Todos os direitos reservados</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.toast').forEach(function (el) {
            bootstrap.Toast.getOrCreateInstance(el).show();
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
