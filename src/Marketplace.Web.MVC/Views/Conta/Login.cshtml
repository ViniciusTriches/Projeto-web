@model Marketplace.Web.MVC.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="text-center mb-4">
            <i class="bi bi-box-arrow-in-right" style="font-size:2.5rem;color:var(--color-accent)"></i>
            <h3 class="mt-2 fw-bold">Entrar na sua conta</h3>
            <p class="small" style="color:var(--color-text-muted)">Bem-vindo de volta ao Marketplace</p>
        </div>

        <div class="card shadow border-0" style="max-width:420px;margin:0 auto;">
            <div class="card-body p-4">
                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">E-mail</label>
                        <input asp-for="Email" class="form-control" placeholder="seu@email.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-2">
                        <label asp-for="Senha" class="form-label">Senha</label>
                        <div class="input-group">
                            <input asp-for="Senha" type="password" class="form-control" id="campoSenha" placeholder="••••••••" autocomplete="current-password" />
                            <button type="button" class="btn btn-outline-secondary toggle-senha" data-target="campoSenha" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Senha" class="text-danger small"></span>
                    </div>

                    <div class="text-end mb-4">
                        <a asp-action="EsqueciSenha" class="text-decoration-none small" style="color:var(--color-accent)">Esqueci minha senha</a>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                        </button>
                    </div>
                </form>

                <hr style="border-color:var(--color-border)" />
                <p class="text-center mb-0 small" style="color:var(--color-text-muted)">
                    Não tem conta?
                    <a asp-action="Cadastro" class="fw-semibold" style="color:var(--color-accent)">Cadastre-se aqui</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
