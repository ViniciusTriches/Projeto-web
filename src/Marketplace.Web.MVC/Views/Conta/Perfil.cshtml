@model Marketplace.Web.MVC.Models.ViewModels.PerfilViewModel
@using Marketplace.Web.MVC.Models.ApiContracts.Usuarios
@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 text-center p-4">
            <div class="mb-3">
                <i class="bi bi-person-circle text-primary" style="font-size:5rem;"></i>
            </div>
            <h5 class="fw-bold">@Model.Nome</h5>
            <span class="badge bg-secondary mb-2">@Model.Funcao</span>
            <p class="text-muted small mb-1"><i class="bi bi-envelope me-1"></i>@Model.Email</p>
            @if (!string.IsNullOrEmpty(Model.Telefone))
            {
                <p class="text-muted small mb-1"><i class="bi bi-telephone me-1"></i>@Model.Telefone</p>
            }
            <p class="text-muted small mb-1">
                <i class="bi bi-calendar me-1"></i>Membro desde @Model.CriadoEm.ToString("MMM yyyy")
            </p>
            <span class="badge @(Model.Status == EUsuarioStatus.Ativo ? "bg-success" : "bg-danger")">
                @Model.Status
            </span>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Perfil</h5>
            </div>
            <div class="card-body">
                <form asp-action="Perfil" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">E-mail</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Documento</label>
                        <input value="@Model.Documento" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo de Pessoa</label>
                        <input value="@(Model.TipoPessoa == ETipoPessoa.PessoaFisica ? "Pessoa Física" : "Pessoa Jurídica")" class="form-control" readonly />
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-2"></i>Salvar Alterações
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
