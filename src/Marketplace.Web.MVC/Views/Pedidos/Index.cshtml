@model Marketplace.Web.MVC.Models.ApiContracts.Pedidos.CarrinhoRetornoDto?
@{
    ViewData["Title"] = "Meus Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bag me-2"></i>Meus Pedidos</h4>
</div>

@if (Model == null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Não foi possível carregar seus pedidos. Tente novamente mais tarde.
    </div>
}
else if (!Model.PedidosModel.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag-x text-muted" style="font-size:5rem;"></i>
        <h5 class="mt-3 text-muted">Nenhum pedido encontrado</h5>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-shop me-2"></i>Ir às Compras
        </a>
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h4 fw-bold text-primary mb-0">@Model.PedidosModel.Count</div>
                <small class="text-muted">Total de Pedidos</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h4 fw-bold text-success mb-0">
                    R$ @Model.ValorTotalCarrinho.ToString("N2")
                </div>
                <small class="text-muted">Valor Total</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h4 fw-bold text-warning mb-0">
                    @Model.PedidosModel.Count(p => p.StatusPedido == 0)
                </div>
                <small class="text-muted">Pendentes</small>
            </div>
        </div>
    </div>

    @foreach (var pedido in Model.PedidosModel.OrderByDescending(p => p.DataPedido))
    {
        var statusClass = pedido.StatusPedido switch
        {
            1 => "badge-status-concluido text-white",
            -1 => "badge-status-cancelado text-white",
            _ => "badge-status-pendente"
        };

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header d-flex justify-content-between align-items-center bg-white py-3">
                <div>
                    <span class="fw-semibold me-3">
                        <i class="bi bi-receipt me-1"></i>Pedido <code>@pedido.Id.ToString()[..8].ToUpper()</code>
                    </span>
                    <span class="text-muted small">@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <span class="badge @statusClass fs-6 px-3 py-2">
                    @pedido.TextoStatusPedido
                </span>
            </div>
            <div class="card-body">
                @if (pedido.ProdutosModel.Any())
                {
                    <table class="table table-sm table-borderless mb-0">
                        <thead class="text-muted">
                            <tr>
                                <th>Produto</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-end">Preço Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prod in pedido.ProdutosModel)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-box-seam me-1 text-muted"></i>
                                        <a asp-controller="Produtos" asp-action="Detalhe" asp-route-id="@prod.ProdutoId"
                                           class="text-decoration-none">@prod.ProdutoId.ToString()[..8]…</a>
                                    </td>
                                    <td class="text-center">@prod.Quantidade</td>
                                    <td class="text-end">R$ @prod.Preco.ToString("N2")</td>
                                    <td class="text-end">R$ @((prod.Preco * prod.Quantidade).ToString("N2"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                    <div class="text-muted small">
                        @if (!string.IsNullOrEmpty(pedido.CEPEnderecoEntrega))
                        {
                            <i class="bi bi-geo-alt me-1"></i>
                            <span>CEP: @pedido.CEPEnderecoEntrega @(string.IsNullOrEmpty(pedido.NumeroEnderecoEntrega) ? "" : $"nº {pedido.NumeroEnderecoEntrega}")</span>
                        }
                    </div>
                    <div class="fw-bold fs-5 text-primary">
                        Total: R$ @pedido.ValorTotal.ToString("N2")
                    </div>
                </div>
            </div>
        </div>
    }
}
