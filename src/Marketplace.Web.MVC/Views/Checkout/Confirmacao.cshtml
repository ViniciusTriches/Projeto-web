@model Marketplace.Web.MVC.Models.ViewModels.ConfirmacaoViewModel
@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center p-5">
                @if (Model.Aprovado)
                {
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size:5rem;"></i>
                    </div>
                    <h3 class="fw-bold text-success mb-2">Pedido Confirmado!</h3>
                    <p class="text-muted">Seu pagamento foi processado com sucesso.</p>
                }
                else
                {
                    <div class="mb-4">
                        <i class="bi bi-clock-history text-warning" style="font-size:5rem;"></i>
                    </div>
                    <h3 class="fw-bold text-warning mb-2">Pedido Recebido!</h3>
                    <p class="text-muted">Seu pedido foi registrado. O pagamento está sendo processado.</p>
                }

                <div class="card bg-light border-0 my-4">
                    <div class="card-body text-start">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Número do Pedido:</dt>
                            <dd class="col-sm-7 text-monospace"><code>@Model.PedidoId.ToString()[..8].ToUpper()</code></dd>

                            <dt class="col-sm-5">Pagamento:</dt>
                            <dd class="col-sm-7">@Model.MetodoPagamento</dd>

                            <dt class="col-sm-5">Produtos:</dt>
                            <dd class="col-sm-7">R$ @Model.TotalProdutos.ToString("N2")</dd>

                            <dt class="col-sm-5">Frete:</dt>
                            <dd class="col-sm-7">R$ @Model.ValorFrete.ToString("N2")</dd>

                            <dt class="col-sm-5 fw-bold">Total:</dt>
                            <dd class="col-sm-7 fw-bold text-primary fs-5">R$ @Model.ValorTotal.ToString("N2")</dd>
                        </dl>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <a asp-controller="Pedidos" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-bag me-2"></i>Meus Pedidos
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-shop me-2"></i>Continuar Comprando
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
