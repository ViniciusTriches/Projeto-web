@model Marketplace.Web.MVC.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Marketplace";
}

<div class="row">
    <!-- Sidebar categorias -->
    <div class="col-lg-2 mb-4">
        <div class="card shadow-sm border-0 sidebar-categorias">
            <div class="card-header bg-dark text-white fw-semibold">
                <i class="bi bi-tags me-1"></i> Categorias
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Home" asp-action="Index"
                   class="list-group-item list-group-item-action @(Model.TermoBusca == null ? "active" : "")">
                    Todos
                </a>
                @foreach (var cat in Model.Categorias)
                {
                    <a asp-controller="Home" asp-action="Buscar" asp-route-q="@cat.Nome"
                       class="list-group-item list-group-item-action small">
                        @cat.Nome
                    </a>
                }
                @if (!Model.Categorias.Any())
                {
                    <div class="list-group-item text-muted small">Indisponível</div>
                }
            </div>
        </div>
    </div>

    <!-- Grid produtos -->
    <div class="col-lg-10">
        @if (!string.IsNullOrEmpty(Model.TermoBusca))
        {
            <div class="mb-3">
                <h5>Resultados para: <strong>@Model.TermoBusca</strong></h5>
                @if (!Model.Produtos.Any())
                {
                    <div class="alert alert-info">Nenhum produto encontrado para "@Model.TermoBusca".</div>
                }
            </div>
        }

        @if (Model.Produtos.Any())
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
                @foreach (var produto in Model.Produtos.Where(p => !p.Excluido && p.Disponivel))
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm card-produto">
                            <div class="card-body d-flex flex-column">
                                <div class="text-center mb-3">
                                    <i class="bi bi-box-seam text-muted" style="font-size:3rem;"></i>
                                </div>
                                <h6 class="card-title fw-semibold text-truncate" title="@produto.Nome">@produto.Nome</h6>
                                <p class="text-muted small flex-grow-1" style="overflow:hidden;max-height:3em;">@produto.Descricao</p>
                                <div class="mt-auto">
                                    <p class="fs-5 fw-bold text-primary mb-2">R$ @produto.Preco.ToString("N2")</p>
                                    @if (produto.QuantidadeEstoque > 0)
                                    {
                                        <span class="badge bg-success-subtle text-success mb-2">Em estoque</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger mb-2">Sem estoque</span>
                                    }
                                    <div class="d-grid">
                                        <a asp-controller="Produtos" asp-action="Detalhe" asp-route-id="@produto.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye me-1"></i>Ver Produto
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (string.IsNullOrEmpty(Model.TermoBusca))
        {
            <div class="text-center py-5">
                <i class="bi bi-box-seam text-muted" style="font-size:4rem;"></i>
                <p class="text-muted mt-3">Nenhum produto disponível no momento.</p>
            </div>
        }
    </div>
</div>
