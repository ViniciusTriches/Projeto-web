@model Marketplace.Web.MVC.Models.Carrinho.CarrinhoSession
@{
    ViewData["Title"] = "Meu Carrinho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cart3 me-2"></i>Meu Carrinho</h4>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Continuar Comprando
    </a>
</div>

@if (!Model.Itens.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x text-muted" style="font-size:5rem;"></i>
        <h5 class="mt-3 text-muted">Seu carrinho está vazio</h5>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-shop me-2"></i>Ver Produtos
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Produto</th>
                                <th class="text-end">Preço</th>
                                <th class="text-center" style="width:120px;">Qtd</th>
                                <th class="text-end">Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Itens)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-box-seam text-muted fs-5"></i>
                                            <span class="fw-semibold">@item.Nome</span>
                                        </div>
                                    </td>
                                    <td class="text-end">R$ @item.Preco.ToString("N2")</td>
                                    <td>
                                        <form asp-action="AtualizarQuantidade" method="post" class="d-flex justify-content-center">
                                            <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                            <input type="number" name="quantidade" value="@item.Quantidade"
                                                   min="1" class="form-control form-control-sm text-center"
                                                   style="width:70px;"
                                                   onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="text-end fw-bold text-primary">R$ @item.Subtotal.ToString("N2")</td>
                                    <td class="text-end">
                                        <form asp-action="Remover" method="post">
                                            <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Remover este item?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <form asp-action="Limpar" method="post" class="mt-3">
                <button type="submit" class="btn btn-outline-secondary btn-sm"
                        onclick="return confirm('Esvaziar o carrinho?')">
                    <i class="bi bi-trash me-1"></i>Esvaziar Carrinho
                </button>
            </form>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-semibold">
                    Resumo do Pedido
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Itens (@Model.TotalItens)</span>
                        <span>R$ @Model.Total.ToString("N2")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span class="text-primary">R$ @Model.Total.ToString("N2")</span>
                    </div>
                    <div class="d-grid mt-4">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg">
                                <i class="bi bi-credit-card me-2"></i>Finalizar Compra
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Conta" asp-action="Login"
                               asp-route-returnUrl="/Checkout" class="btn btn-success btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Entrar para Comprar
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
